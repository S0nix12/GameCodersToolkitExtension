<Window x:Class="GameCodersToolkit.FileRenamer.Windows.RenameFileWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
		xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
		xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
		xmlns:platformUI="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
		xmlns:vshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
		xmlns:vm="clr-namespace:GameCodersToolkit.FileRenamer.ViewModels"
		xmlns:local="clr-namespace:GameCodersToolkit.FileRenamer.Windows"
		xmlns:converters="clr-namespace:GameCodersToolkitShared.FileRenamer.Converters"
		d:DataContext="{d:DesignInstance Type=vm:CRenameFileDialogViewModel}"
		mc:Ignorable="d"
		Height="700"
		Width="800"
		toolkit:Themes.UseVsTheme="True"
		WindowStartupLocation="CenterOwner"
		Title="{Binding WindowTitle}">

	<Window.Resources>
		<GridLength x:Key="WindowContentMargin">15</GridLength>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <converters:BoolToResultColorConverter x:Key="BoolToResultColorConverter" />
		<BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
		<Style TargetType="{x:Type TextBlock}" x:Key="VSTextBlockStyle">
			<Setter Property="Foreground" Value="{DynamicResource {x:Static vshell:VsBrushes.WindowTextKey}}"/>
			<Setter Property="FontSize" Value="16" />
		</Style>
	</Window.Resources>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="{StaticResource WindowContentMargin}" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="{StaticResource WindowContentMargin}" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="{StaticResource WindowContentMargin}" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="25" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="25" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="25" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="25" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="25" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="*" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="{StaticResource WindowContentMargin}" />
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource VSTextBlockStyle}">Files to rename/move</TextBlock>
		<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
					  Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
					  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
			<ItemsControl ItemsSource="{Binding RelatedFiles}">
				<ItemsControl.ItemTemplate>
					<DataTemplate DataType="{x:Type vm:CRelatedFileViewModel}">
						<CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,3">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="{Binding FileName}" Style="{StaticResource VSTextBlockStyle}" />
							</StackPanel>
						</CheckBox>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

		<Separator Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" />

		<TextBlock Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource VSTextBlockStyle}">Owning CMake file</TextBlock>
		<TextBlock Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="3"
				   Text="{Binding OwningCMakeFileDisplay}" Style="{StaticResource VSTextBlockStyle}"
				   Opacity="0.7" TextTrimming="CharacterEllipsis"
				   ToolTip="{Binding OwningCMakeFileDisplay}" />

		<Separator Grid.Row="11" Grid.Column="1" Grid.ColumnSpan="3" />

		<TextBlock Grid.Row="13" Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource VSTextBlockStyle}">New file name (without extension)</TextBlock>
		<TextBox Grid.Row="15" Grid.Column="1" Grid.ColumnSpan="3"
				 Text="{Binding NewFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
				 FontSize="16" Padding="4"
				 IsEnabled="{Binding IsRenaming, Converter={StaticResource InverseBooleanConverter}}"
				 x:Name="NewNameTextBox" />

		<TextBlock Grid.Row="17" Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource VSTextBlockStyle}">New location (must be sub-location of CMake file)</TextBlock>
		<TextBox Grid.Row="19" Grid.Column="1"
				 Text="{Binding NewDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
				 FontSize="16" Padding="4"
				 IsEnabled="{Binding IsRenaming, Converter={StaticResource InverseBooleanConverter}}"
				 ToolTip="{Binding NewDirectory}" />
		<Button Grid.Row="19" Grid.Column="3"
				Content="Browse..."
				Command="{Binding BrowseForFolderCommand}"
				Padding="12,4" FontSize="16"
				IsEnabled="{Binding IsRenaming, Converter={StaticResource InverseBooleanConverter}}" />

		<Separator Grid.Row="21" Grid.Column="1" Grid.ColumnSpan="3" />

		<TextBlock Grid.Row="23" Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource VSTextBlockStyle}">Results</TextBlock>

		<DockPanel Grid.Row="25" Grid.Column="1" Grid.ColumnSpan="3">
			<!-- Progress indicator (visible while renaming) -->
			<StackPanel DockPanel.Dock="Top" Margin="0,0,0,8"
						Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVisibilityConverter}}">
				<ProgressBar IsIndeterminate="True" Height="4" />
				<TextBlock Text="{Binding ProgressMessage}" Style="{StaticResource VSTextBlockStyle}"
						   Opacity="0.8" Margin="0,4,0,0" />
			</StackPanel>

			<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
						  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
				<ItemsControl ItemsSource="{Binding RenameResults}">
					<ItemsControl.ItemTemplate>
						<DataTemplate DataType="{x:Type vm:CRenameResultViewModel}">
							<StackPanel Orientation="Horizontal" Margin="0,2">
								<TextBlock Text="{Binding Description}"
										   Foreground="{Binding IsSuccess, Converter={StaticResource BoolToResultColorConverter}}"
										   Style="{StaticResource VSTextBlockStyle}" TextWrapping="WrapWithOverflow" />
							</StackPanel>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>
		</DockPanel>

		<Grid Grid.Row="27" Grid.Column="1" Grid.ColumnSpan="3">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="10" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<TextBlock Grid.Column="0" Text="{Binding ErrorMessage}"
					   Foreground="Red" Style="{StaticResource VSTextBlockStyle}"
					   TextWrapping="WrapWithOverflow" VerticalAlignment="Center" />

			<Button Grid.Column="1" Content="Rename / Move" Command="{Binding RenameCommand}"
					Padding="12,6" MinWidth="120" FontSize="16"
					IsEnabled="{Binding IsRenaming, Converter={StaticResource InverseBooleanConverter}}" />
			<Button Grid.Column="3" Content="Close" Command="{Binding CloseCommand}"
					Padding="12,6" MinWidth="100" FontSize="16" />
		</Grid>
	</Grid>
</Window>
