<UserControl x:Class="GameCodersToolkit.FileRenamer.Controls.CMakeSelectionControl"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
			 xmlns:vshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
			 xmlns:ftvm="clr-namespace:GameCodersToolkit.FileTemplateCreator.ViewModels"
			 xmlns:vm="clr-namespace:GameCodersToolkit.FileRenamer.ViewModels"
			 xmlns:converters="clr-namespace:GameCodersToolkitShared.FileRenamer.Converters"
			 d:DataContext="{d:DesignInstance Type=vm:CCMakeSelectionHelper}"
			 mc:Ignorable="d">

	<UserControl.Resources>
		<Style TargetType="{x:Type TextBlock}" x:Key="VSTextBlockStyle">
			<Setter Property="Foreground" Value="{DynamicResource {x:Static vshell:VsBrushes.WindowTextKey}}"/>
			<Setter Property="FontSize" Value="16" />
		</Style>
		<BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
		<converters:NotNullToBoolConverter x:Key="NotNullToBoolConverter" />
	</UserControl.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="200" />
			<RowDefinition Height="8" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- CMake File list + Uber/Group tree side by side -->
		<Grid Grid.Row="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="15" />
				<ColumnDefinition Width="2*" />
			</Grid.ColumnDefinitions>

			<!-- CMake Files list -->
			<Border Grid.Column="0" BorderBrush="{DynamicResource {x:Static vshell:VsBrushes.ActiveBorderKey}}" BorderThickness="1">
				<DockPanel>
					<TextBlock DockPanel.Dock="Top" Text="CMake File" Style="{StaticResource VSTextBlockStyle}"
							   FontSize="14" Margin="4,2" Opacity="0.7" />
					<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
						<TreeView ItemsSource="{Binding CMakeFiles}" toolkit:Themes.UseVsTheme="True">
							<TreeView.Resources>
								<Style TargetType="{x:Type TreeViewItem}">
									<Setter Property="Focusable" Value="{Binding IsFocusable, Mode=TwoWay}"/>
									<Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
									<Style.Resources>
										<SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{x:Static SystemColors.HighlightColor}"/>
									</Style.Resources>
								</Style>
								<DataTemplate DataType="{x:Type ftvm:CMakeFileViewModel}">
									<StackPanel Orientation="Horizontal">
										<TextBlock Text="{Binding ID}" Style="{StaticResource VSTextBlockStyle}" />
									</StackPanel>
								</DataTemplate>
							</TreeView.Resources>
						</TreeView>
					</ScrollViewer>
				</DockPanel>
			</Border>

			<!-- Uber File / Group tree -->
			<Border Grid.Column="2" BorderBrush="{DynamicResource {x:Static vshell:VsBrushes.ActiveBorderKey}}" BorderThickness="1">
				<DockPanel>
					<TextBlock DockPanel.Dock="Top" Text="Uber File / Group (click group to select)" Style="{StaticResource VSTextBlockStyle}"
							   FontSize="14" Margin="4,2" Opacity="0.7" />
					<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
						<TreeView ItemsSource="{Binding MakeFileContent}" toolkit:Themes.UseVsTheme="True"
								  SelectedItemChanged="MakeFileTree_SelectedItemChanged">
							<TreeView.Resources>
								<Style TargetType="{x:Type TreeViewItem}">
									<Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
									<Setter Property="Focusable" Value="True"/>
									<Style.Resources>
										<SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{x:Static SystemColors.HighlightColor}"/>
									</Style.Resources>
								</Style>
								<HierarchicalDataTemplate DataType="{x:Type ftvm:CMakeFileUberFileViewModel}" ItemsSource="{Binding Children}">
									<StackPanel Orientation="Horizontal">
										<TextBlock Text="&#xE903;" FontFamily="Segoe MDL2 Assets" FontSize="12"
												   Foreground="CornflowerBlue" VerticalAlignment="Center" Margin="0,0,4,0"
												   Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
										<TextBlock Text="{Binding DisplayName}" Style="{StaticResource VSTextBlockStyle}" Foreground="CornflowerBlue" />
									</StackPanel>
								</HierarchicalDataTemplate>
								<HierarchicalDataTemplate DataType="{x:Type ftvm:CMakeFileGroupViewModel}" ItemsSource="{Binding Children}">
									<StackPanel Orientation="Horizontal" Cursor="Hand">
										<TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
												   Foreground="LimeGreen" VerticalAlignment="Center" Margin="0,0,4,0"
												   Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
										<TextBlock Text="{Binding DisplayName}" Style="{StaticResource VSTextBlockStyle}" Foreground="LimeGreen" />
									</StackPanel>
								</HierarchicalDataTemplate>
								<DataTemplate DataType="{x:Type ftvm:CMakeFileFileViewModel}">
									<StackPanel Orientation="Horizontal">
										<TextBlock Text="{Binding Name}" Style="{StaticResource VSTextBlockStyle}" Opacity="0.6" />
									</StackPanel>
								</DataTemplate>
								<DataTemplate DataType="{x:Type ftvm:CSelectableEntryViewModel}">
									<StackPanel Orientation="Horizontal">
										<Button Command="{Binding SelectCommand}" Padding="4,2" Cursor="Hand">
											<TextBlock Text="{Binding Name}" Style="{StaticResource VSTextBlockStyle}" FontSize="14" />
										</Button>
									</StackPanel>
								</DataTemplate>
							</TreeView.Resources>
						</TreeView>
					</ScrollViewer>
				</DockPanel>
			</Border>
		</Grid>

		<!-- Add new uber file / group controls -->
		<StackPanel Grid.Row="2" Orientation="Vertical">
			<Grid Margin="0,2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="8" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="8" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="New Uber File:" Style="{StaticResource VSTextBlockStyle}" FontSize="14" VerticalAlignment="Center" />
				<TextBox Grid.Column="2" Text="{Binding NewUberFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						 FontSize="14" Padding="2" VerticalAlignment="Center" />
				<Button Grid.Column="4" Content="Add" Command="{Binding AddNewUberFileCommand}"
						Padding="8,2" FontSize="14" />
			</Grid>
			<Grid Margin="0,2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="8" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="8" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="New Group:" Style="{StaticResource VSTextBlockStyle}" FontSize="14" VerticalAlignment="Center" />
				<TextBox Grid.Column="2" Text="{Binding NewGroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						 FontSize="14" Padding="2" VerticalAlignment="Center"
						 IsEnabled="{Binding SelectedUberFile, Converter={StaticResource NotNullToBoolConverter}}" />
				<Button Grid.Column="4" Content="Add" Command="{Binding AddNewGroupCommand}"
						Padding="8,2" FontSize="14" />
			</Grid>
		</StackPanel>
	</Grid>
</UserControl>
